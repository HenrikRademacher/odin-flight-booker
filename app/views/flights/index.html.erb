<h1>Search for flights:</h1>
<%= form_with url: "/flights", method: :get do |form| %>
    <%= form.label :dep, "From:" %>
    <% if params[:dep] %>
        <%= form.collection_select :dep, @airports, :code, :name, selected: params[:dep] %>
    <% else %>
        <%= form.collection_select :dep, @airports, :code, :name %>
    <% end %>
    <%= form.label :arr, "To:" %>
    <% if params[:arr] %>
        <%= form.collection_select :arr, @airports, :code, :name, selected: params[:arr] %>
    <% else %>
        <%= form.collection_select :arr, @airports, :code, :name, selected: @airports[1].code %>
    <% end %>
    <%= form.label :amount, "Ticket amount:" %>
    <% if params[:amount] %>
        <%= form.number_field :amount, value: params[:amount] %>
    <% else %>
        <%= form.number_field :amount, value: 1 %>
    <% end %>
    <%= form.label :day %>
    <% if params[:day] %>
        <%= form.select :day, @departures, selected: params[:day] %>
    <% else %>
        <%= form.select :day, @departures %>
    <% end %>
    <%= form.submit "Filter" %>
<% end %>
<%= form_with url: "/bookings/new", method: :get do |form| %>
    <% if params[:amount] %>
        <%= form.hidden_field :amount, value: params[:amount] %>
    <% else %>
        <%= form.hidden_field :amount, value: 1 %>
    <% end %>
    <h1>Available flights:</h1>
    <ul>
        <% @flights.first(10).each do |flight| %>
            <div class="flight_card">
                <%= form.radio_button :flight, flight.id %>
                <label for="flight_<%= flight.id %>">
                    <li>
                        From: <%= flight.departure_airport.name %><br>
                        To: <%= flight.arrival_airport.name %><br>
                        Departure: <%= flight.departure %>
                    </li>
                </label>
            </div>
        <% end %>
    </ul>
    <%= form.submit "Book flight" %>
<% end %>
